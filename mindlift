/* ============================================
STREAK — uses localStorage to remember last visit date
Each new calendar day the user opens the app counts as +1
============================================ */
function calcStreak() {
const today = new Date().toDateString(); // e.g. "Sat Mar 21 2026"
const lastVisit = localStorage.getItem('ml_last_visit');
let streak = parseInt(localStorage.getItem('ml_streak') || '0', 10);
if (!lastVisit) {
// Very first time ever
streak = 1;
} else if (lastVisit === today) {
// Same day — streak stays, don't increment
// streak is already correct in localStorage
} else {
// Check if yesterday
const yesterday = new Date();
yesterday.setDate(yesterday.getDate() - 1);
if (lastVisit === yesterday.toDateString()) {
streak += 1; // consecutive day → increment
} else {
streak = 1; // missed a day → reset
}
}
localStorage.setItem('ml_last_visit', today);
localStorage.setItem('ml_streak', streak);
return streak;
}
