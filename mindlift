// Add 'selected' to the clicked one
document.getElementById('mood-' + mood).classList.add('selected');
// Reset language to English
currentLang = 'en';
document.querySelectorAll('.lang-tab').forEach(t => t.classList.remove('active'));
document.querySelectorAll('.lang-tab')[0].classList.add('active');
// Reset reactions
likeCount = 0;
dislikeCount = 0;
userReaction = null;
updateReactionUI();
// Pick a random quote for this mood
pickRandomQuote();
// Show the quote section
document.getElementById('quoteSection').style.display = 'block';
// Scroll down so user can see the quote
setTimeout(() => {
document.getElementById('quoteSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
}, 100);
}
/* ============================================
PICK A RANDOM QUOTE
Tries not to repeat the same quote twice in a row
============================================ */
function pickRandomQuote() {
const pool = QUOTES[currentMood];
// If we've used all quotes, reset the tracker
if (!usedQuotes[currentMood]) usedQuotes[currentMood] = [];
if (usedQuotes[currentMood].length >= pool.length) {
usedQuotes[currentMood] = [];
}
// Get indexes that haven't been used recently
const available = pool
.map((_, i) => i)
.filter(i => !usedQuotes[currentMood].includes(i));
// Pick a random one from available
const idx = available[Math.floor(Math.random() * available.length)];
usedQuotes[currentMood].push(idx);
currentQuote = pool[idx];
// Display the quote
displayQuote();
}
/* ============================================
DISPLAY CURRENT QUOTE IN CURRENT LANGUAGE
============================================ */
function displayQuote() {
if (!currentQuote) return;
const info = MOOD_INFO[currentMood];
// Set text
document.getElementById('quoteText').textContent = currentQuote[currentLang];
document.getElementById('quoteAuthor').textContent = '— ' + currentQuote.author;
document.getElementById('quoteMoodTag').textContent = info.emoji + ' ' + info.label;
// Change the colour strip at top of card

document.querySelector('.quote-mood-strip').style.background =
'linear-gradient(90deg, ' + info.color + ', #ffd166)';
// Replay fade-in animation
const card = document.getElementById('quoteCard');
card.style.animation = 'none';
void card.offsetWidth; // force reflow
card.style.animation = 'fadeIn 0.5s ease both';
}
