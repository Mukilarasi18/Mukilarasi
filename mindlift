<!DOCTYPE HTML>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MindLift – Your Daily Motivation</title>
<!-- Google Fonts: Bebas Neue for big headings, Nunito for body text -->
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800;900&displa
y=swap" rel="stylesheet" />
<style>
/* =============================================
GLOBAL RESET & VARIABLES
============================================= */
* {
margin: 0;
padding: 0;
box-sizing: border-box;
}
:root {
--navy: #0a0f1e; /* dark background */
--blue: #1e3a5f; /* medium blue */
--orange: #ff6b35; /* main accent */
--yellow: #ffd166; /* warm highlight */
--white: #ffffff;
--offwhite:#f4f6fb;
--gray: #6b7280;
--dark: #111827;
--green: #22c55e;
--red: #ef4444;
}
body {
font-family: 'Nunito', sans-serif;
overflow-x: hidden;
}
h1, h2, h3 {
font-family: 'Bebas Neue', cursive;
letter-spacing: 1.5px;

}
/* =============================================
SCREEN SYSTEM — only .active screen shows
============================================= */
.screen {
display: none;
min-height: 100vh;
}
.screen.active {
display: block;
}
/* =============================================
SCREEN 1 — LANDING PAGE
============================================= */
#landing {
background-color: var(--navy);
position: relative;
overflow: hidden;
}
/* Floating emoji particles in the background */
.particles {
position: absolute;
inset: 0;
pointer-events: none;
overflow: hidden;
}
.particle {
position: absolute;
font-size: 28px;
opacity: 0.12;
animation: floatUp linear infinite;
}
/* Each particle gets a different position and speed */
.particle:nth-child(1) { left: 5%; animation-duration: 9s; animation-delay: 0s; font-size: 24px; }
.particle:nth-child(2) { left: 15%; animation-duration: 12s; animation-delay: 2s; font-size: 32px; }
.particle:nth-child(3) { left: 25%; animation-duration: 8s; animation-delay: 1s; font-size: 20px; }
.particle:nth-child(4) { left: 35%; animation-duration: 14s; animation-delay: 3s; font-size: 28px; }
.particle:nth-child(5) { left: 50%; animation-duration: 10s; animation-delay: 0.5s; font-size: 36px; }
.particle:nth-child(6) { left: 62%; animation-duration: 11s; animation-delay: 4s; font-size: 22px; }
.particle:nth-child(7) { left: 72%; animation-duration: 7s; animation-delay: 2.5s; font-size: 30px; }
.particle:nth-child(8) { left: 82%; animation-duration: 13s; animation-delay: 1.5s; font-size: 26px; }
.particle:nth-child(9) { left: 90%; animation-duration: 9s; animation-delay: 3.5s; font-size: 24px; }
.particle:nth-child(10) { left: 45%; animation-duration: 15s; animation-delay: 0s; font-size: 40px; }
@keyframes floatUp {
0% { transform: translateY(110vh) rotate(0deg); opacity: 0; }
10% { opacity: 0.12; }
90% { opacity: 0.12; }
100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
}
/* Orange diagonal stripe across the background */
.landing-stripe {
position: absolute;
width: 120%;
height: 320px;
background: linear-gradient(135deg, var(--orange), #e05520);
top: -80px;
right: -10%;
transform: rotate(-8deg);
opacity: 0.08;
border-radius: 40px;
}
/* Main content wrapper */
.landing-content {
position: relative;
z-index: 10;
max-width: 860px;
margin: 0 auto;
padding: 60px 24px 80px;
text-align: center;

}
/* Top badge */
.landing-badge {
display: inline-block;
background: rgba(255, 107, 53, 0.15);
border: 1px solid rgba(255, 107, 53, 0.4);
color: var(--orange);
font-size: 12px;
font-weight: 800;
padding: 6px 20px;
border-radius: 30px;
letter-spacing: 2px;
text-transform: uppercase;
margin-bottom: 28px;
animation: fadeDown 0.6s ease both;
}
/* Big hero headline */
.landing-title {
font-size: 88px;
color: var(--white);
line-height: 0.92;
margin-bottom: 20px;
animation: fadeDown 0.7s ease 0.1s both;
}
.landing-title .highlight {
color: var(--orange);
}
.landing-title .thin {
color: rgba(255,255,255,0.35);
}
/* Subtitle */
.landing-sub {
font-size: 18px;
color: rgba(255,255,255,0.6);
max-width: 520px;
margin: 0 auto 48px;
line-height: 1.7;
font-weight: 600;
animation: fadeDown 0.7s ease 0.2s both;
}
/* Feature pills row */
.feature-row {
display: flex;
gap: 12px;
justify-content: center;
flex-wrap: wrap;
margin-bottom: 48px;
animation: fadeDown 0.7s ease 0.3s both;
}
.feature-pill {
background: rgba(255,255,255,0.07);
border: 1px solid rgba(255,255,255,0.12);
color: rgba(255,255,255,0.75);
font-size: 13px;
font-weight: 700;
padding: 8px 20px;
border-radius: 30px;
}
.feature-pill span {
margin-right: 6px;
}
/* CTA Button */
.cta-btn {
display: inline-block;
background: var(--orange);
color: var(--white);
font-family: 'Nunito', sans-serif;
font-size: 18px;
font-weight: 900;

padding: 18px 52px;
border-radius: 16px;
border: none;
cursor: pointer;
letter-spacing: 0.5px;
transition: transform 0.2s, box-shadow 0.2s;
box-shadow: 0 8px 32px rgba(255, 107, 53, 0.45);
animation: fadeDown 0.7s ease 0.4s both;
}
.cta-btn:hover {
transform: translateY(-3px);
box-shadow: 0 14px 40px rgba(255, 107, 53, 0.55);
}
.cta-btn:active {
transform: translateY(0px);
}
/* Scroll arrow hint */
.scroll-hint {
margin-top: 60px;
color: rgba(255,255,255,0.25);
font-size: 13px;
font-weight: 700;
animation: fadeDown 0.7s ease 0.6s both;
}
/* Preview cards row at the bottom of landing */
.preview-row {
display: flex;
gap: 16px;
justify-content: center;
flex-wrap: wrap;
margin-top: 20px;
animation: fadeDown 0.7s ease 0.5s both;
}
.preview-card {
background: rgba(255,255,255,0.05);
border: 1px solid rgba(255,255,255,0.1);
border-radius: 18px;
padding: 22px 28px;
text-align: center;
min-width: 150px;
}
.preview-card .pnum {
font-family: 'Bebas Neue', cursive;
font-size: 44px;
color: var(--orange);
line-height: 1;
}
.preview-card .plabel {
font-size: 12px;
color: rgba(255,255,255,0.5);
font-weight: 700;
margin-top: 4px;
}
/* =============================================
SCREEN 2 — ONBOARDING
============================================= */
#onboarding {
background: linear-gradient(135deg, #f4f6fb 0%, #e8ecf5 100%);
padding: 40px 20px;
}
/* Flex centering wrapper INSIDE onboarding screen */
.onboarding-inner {
display: flex;
align-items: center;
justify-content: center;
min-height: calc(100vh - 80px);
}
.onboard-card {
background: var(--white);

border-radius: 28px;
padding: 48px 44px;
width: 100%;
max-width: 480px;
box-shadow: 0 20px 60px rgba(0,0,0,0.12);
animation: popIn 0.4s ease both;
}
/* Small logo at top */
.onboard-logo {
font-family: 'Bebas Neue', cursive;
font-size: 28px;
color: var(--navy);
margin-bottom: 28px;
}
.onboard-logo span { color: var(--orange); }
.onboard-card h2 {
font-size: 38px;
color: var(--navy);
margin-bottom: 6px;
}
.onboard-card p {
font-size: 14px;
color: var(--gray);
margin-bottom: 30px;
line-height: 1.6;
}
/* Input field label */
.field-label {
font-size: 12px;
font-weight: 800;
color: var(--navy);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 7px;
display: block;
}
/* Text inputs */
.onboard-card input,
.onboard-card select {
width: 100%;
padding: 13px 16px;
border: 2px solid #e5e7eb;
border-radius: 12px;
font-family: 'Nunito', sans-serif;
font-size: 15px;
font-weight: 600;
outline: none;
transition: border-color 0.2s;
margin-bottom: 20px;
color: var(--dark);
background: var(--white);
}
.onboard-card input:focus,
.onboard-card select:focus {
border-color: var(--orange);
}
.onboard-card input::placeholder {
color: #bbb;
}
/* Enter button */
.enter-btn {
width: 100%;
padding: 15px;
background: var(--navy);
color: var(--white);
font-family: 'Nunito', sans-serif;
font-size: 16px;
font-weight: 900;
border: none;

border-radius: 14px;
cursor: pointer;
transition: background 0.2s, transform 0.15s;
letter-spacing: 0.5px;
}
.enter-btn:hover {
background: var(--orange);
transform: translateY(-2px);
}
/* Error message */
.error-msg {
color: var(--red);
font-size: 13px;
font-weight: 700;
margin-top: -14px;
margin-bottom: 14px;
display: none;
}
/* =============================================
SCREEN 3 — MAIN APP
============================================= */
#mainapp {
background: var(--offwhite);
}
/* Top bar */
.app-topbar {
background: var(--navy);
padding: 0 24px;
height: 60px;
display: flex;
align-items: center;
justify-content: space-between;
}
.app-logo {
font-family: 'Bebas Neue', cursive;
font-size: 24px;
color: var(--orange);
}
.app-logo span { color: var(--white); }
.app-user {
font-size: 13px;
font-weight: 800;
color: rgba(255,255,255,0.7);
}
.app-user strong { color: var(--yellow); }
/* Streak badge */
.streak-badge {
display: flex;
align-items: center;
gap: 5px;
background: rgba(255,209,102,0.12);
border: 1px solid rgba(255,209,102,0.3);
border-radius: 20px;
padding: 4px 12px;
font-size: 12px;
font-weight: 800;
color: var(--yellow);
letter-spacing: 0.3px;
}
.streak-fire {
font-size: 14px;
display: inline-block;
animation: fireAnim 0.8s ease-in-out infinite alternate;
}
@keyframes fireAnim {
from { transform: scale(1); }
to { transform: scale(1.22); }
}
/* Main content wrapper */

.app-content {
max-width: 700px;
margin: 0 auto;
padding: 36px 20px 60px;
}
/* Greeting */
.greeting {
font-size: 13px;
font-weight: 800;
color: var(--gray);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 6px;
}
.greeting-name {
font-size: 34px;
color: var(--navy);
margin-bottom: 4px;
}
.greeting-sub {
font-size: 14px;
color: var(--gray);
margin-bottom: 32px;
}
/* ---- MOOD SECTION ---- */
.mood-heading {
font-size: 20px;
font-weight: 800;
color: var(--navy);
margin-bottom: 16px;
}
.mood-grid {
display: flex;
gap: 12px;
flex-wrap: wrap;
margin-bottom: 36px;
}
.mood-btn {
flex: 1;
min-width: 100px;
background: var(--white);
border: 2px solid #e5e7eb;
border-radius: 18px;
padding: 18px 10px;
cursor: pointer;
text-align: center;
transition: all 0.2s;
font-family: 'Nunito', sans-serif;
}
.mood-btn:hover {
border-color: var(--orange);
transform: translateY(-4px);
box-shadow: 0 8px 24px rgba(0,0,0,0.1);
}
.mood-btn.selected {
border-color: var(--orange);
background: #fff5f0;
transform: translateY(-4px);
box-shadow: 0 8px 24px rgba(255,107,53,0.2);
}
.mood-emoji { font-size: 36px; display: block; margin-bottom: 8px; }
.mood-label { font-size: 13px; font-weight: 800; color: var(--navy); }
/* ---- QUOTE SECTION ---- */
/* Hidden by default — shown after mood is picked */
#quoteSection {
display: none;
}
/* The big quote card */
.quote-card {

background: var(--navy);
border-radius: 24px;
padding: 40px 36px;
color: var(--white);
position: relative;
overflow: hidden;
margin-bottom: 16px;
box-shadow: 0 12px 40px rgba(10,15,30,0.3);
animation: fadeIn 0.5s ease both;
}
/* Decorative big quotation mark */
.quote-card::before {
content: '"';
font-family: 'Bebas Neue', cursive;
font-size: 220px;
color: rgba(255,255,255,0.04);
position: absolute;
top: -50px;
left: 10px;
line-height: 1;
pointer-events: none;
}
/* Mood colour strip at top */
.quote-mood-strip {
height: 5px;
border-radius: 4px;
margin-bottom: 28px;
background: linear-gradient(90deg, var(--orange), var(--yellow));
}
.quote-text {
font-size: 22px;
font-weight: 800;
line-height: 1.55;
color: var(--white);
margin-bottom: 20px;
position: relative;
}
.quote-author {
font-size: 13px;
font-weight: 700;
color: var(--yellow);
letter-spacing: 0.5px;
}
.quote-mood-tag {
display: inline-block;
background: rgba(255,255,255,0.1);
color: rgba(255,255,255,0.7);
font-size: 11px;
font-weight: 800;
padding: 4px 14px;
border-radius: 20px;
margin-top: 14px;
letter-spacing: 1px;
text-transform: uppercase;
}
/* ---- LANGUAGE SWITCHER ---- */
.lang-label {
font-size: 12px;
font-weight: 800;
color: var(--gray);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 10px;
}
.lang-tabs {
display: flex;
gap: 8px;
flex-wrap: wrap;
margin-bottom: 24px;

}
.lang-tab {
padding: 8px 20px;
border-radius: 30px;
border: 2px solid #ddd;
background: var(--white);
font-family: 'Nunito', sans-serif;
font-size: 13px;
font-weight: 800;
cursor: pointer;
transition: all 0.2s;
color: var(--navy);
}
.lang-tab:hover {
border-color: var(--navy);
}
.lang-tab.active {
background: var(--navy);
color: var(--white);
border-color: var(--navy);
}
/* ---- LIKE / DISLIKE ---- */
.reactions {
display: flex;
align-items: center;
gap: 12px;
margin-bottom: 24px;
}
.react-btn {
display: flex;
align-items: center;
gap: 8px;
padding: 12px 24px;
border-radius: 50px;
border: 2px solid #e5e7eb;
background: var(--white);
font-family: 'Nunito', sans-serif;
font-size: 14px;
font-weight: 800;
cursor: pointer;
transition: all 0.2s;
color: var(--dark);
}
.react-btn:hover {
transform: scale(1.05);
}
.react-btn.liked {
background: #fff0f0;
border-color: var(--red);
color: var(--red);
}
.react-btn.disliked {
background: #f0f0ff;
border-color: #6366f1;
color: #6366f1;
}
.react-btn .react-emoji { font-size: 20px; }
/* ---- NEW QUOTE BUTTON ---- */
.new-quote-btn {
width: 100%;
padding: 15px;
background: var(--orange);
color: var(--white);
font-family: 'Nunito', sans-serif;
font-size: 15px;
font-weight: 900;
border: none;
border-radius: 14px;
cursor: pointer;

transition: transform 0.15s, box-shadow 0.15s;
letter-spacing: 0.5px;
}
.new-quote-btn:hover {
transform: translateY(-2px);
box-shadow: 0 8px 28px rgba(255,107,53,0.35);
}
/* Tip below new quote button */
.tip-text {
text-align: center;
font-size: 12px;
color: var(--gray);
margin-top: 10px;
font-weight: 700;
}
/* =============================================
SHARED ANIMATIONS
============================================= */
@keyframes fadeDown {
from { opacity: 0; transform: translateY(-20px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
from { opacity: 0; transform: translateY(16px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes popIn {
from { opacity: 0; transform: scale(0.88); }
to { opacity: 1; transform: scale(1); }
}
@keyframes pulse {
0%, 100% { transform: scale(1); }
50% { transform: scale(1.08); }
}
.pulse { animation: pulse 0.3s ease; }
/* =============================================
RESPONSIVE — small screens
============================================= */
@media (max-width: 500px) {
.landing-title { font-size: 58px; }
.onboard-card { padding: 32px 24px; }
.quote-text { font-size: 18px; }
.mood-btn { min-width: 80px; }
}
</style>
</head>
