currentLang = langCode;
// Update active tab style
document.querySelectorAll('.lang-tab').forEach(t => t.classList.remove('active'));
btnEl.classList.add('active');
// Re-display quote in new language (smooth animation)
displayQuote();
}
/* ============================================
NEW QUOTE BUTTON
============================================ */
function newQuote() {
// Reset reactions
likeCount = 0;
dislikeCount = 0;
userReaction = null;
updateReactionUI();
// Pick new quote
pickRandomQuote();
}
/* ============================================
LIKE / DISLIKE
============================================ */
function react(type) {
// If clicking the same reaction again, undo it
if (userReaction === type) {
userReaction = null;
if (type === 'like') likeCount = Math.max(0, likeCount - 1);
if (type === 'dislike') dislikeCount = Math.max(0, dislikeCount - 1);
} else {
// Undo previous reaction first
if (userReaction === 'like') likeCount = Math.max(0, likeCount - 1);
if (userReaction === 'dislike') dislikeCount = Math.max(0, dislikeCount - 1);
// Apply new reaction
userReaction = type;
if (type === 'like') likeCount++;
if (type === 'dislike') dislikeCount++;
}
updateReactionUI();
// Little bounce animation
const btn = document.getElementById(type === 'like' ? 'likeBtn' : 'dislikeBtn');
btn.classList.add('pulse');
setTimeout(() => btn.classList.remove('pulse'), 300);
}
function updateReactionUI() {
const likeBtn = document.getElementById('likeBtn');
const dislikeBtn = document.getElementById('dislikeBtn');
// Reset styles
likeBtn.classList.remove('liked');
dislikeBtn.classList.remove('disliked');
// Apply active style
if (userReaction === 'like') likeBtn.classList.add('liked');
if (userReaction === 'dislike') dislikeBtn.classList.add('disliked');
// Update counters
document.getElementById('likeCount').textContent = likeCount;
document.getElementById('dislikeCount').textContent = dislikeCount;
}
